{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/config-status",
      "destination": "/api/config-status.ts"
    },
    {
      "source": "/api/classify",
      "destination": "/api/classify.ts"
    },
    {
      "source": "/api/draft-reply",
      "destination": "/api/draft-reply.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
